# Example .env for php-backend
# Copy this file to .env and fill in real values. DO NOT commit real secrets.

# Gemini / Google Generative Language API key (preferred). Example placeholder:
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
# Model to use (default shown):
GEMINI_MODEL=gemini-2.5-flash

# Application environment (use 'local' for development to enable debug info)
APP_ENV=local

# Optional: If you want to use Google OAuth for sign-in, set these
# You must create OAuth credentials in Google Cloud Console and set the
# authorized redirect URI to http://<YOUR_HOST>:5188/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Optional overrides / legacy endpoint (if not using Google Generative API directly)
# GEMINI_ENDPOINT=https://your-gemini-host.example/v1/...

# Notes:
# - After copying to .env, restart the Node (processing) server so env vars are picked up.
# - Keep real API keys and client secrets out of git. Use .env (ignored) and store example here.
